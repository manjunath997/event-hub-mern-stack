# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/event_management

# JWT (use a long random string in production)
JWT_SECRET=change_this_to_a_secure_random_string_min_32_chars
JWT_EXPIRES_IN=7d

# Stripe (optional — leave empty to allow free bookings without payment)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd

# Email notifications (optional — if SMTP not set, booking emails are skipped)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@events.local

# Optional: default admin created by npm run seed
SEED_ADMIN_EMAIL=admin@events.local
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Admin User

# Stripe: price per seat in cents (demo default $1.00 per seat)
STRIPE_AMOUNT_CENTS_PER_SEAT=100
