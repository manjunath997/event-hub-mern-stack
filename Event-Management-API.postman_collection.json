{
  "info": {
    "name": "Event Management System API",
    "description": "Sample requests for the Node.js Event Management backend. Set collection variables: `baseUrl` (e.g. http://localhost:5000) and `token` (JWT after login).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" },
    { "key": "eventId", "value": "" },
    { "key": "bookingId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/health"
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane User\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"secret12\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@events.local\",\n  \"password\": \"admin123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/auth/me"
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "List (search & filter)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/events?q=music&location=Hall&dateFrom=2026-01-01T00:00:00.000Z&dateTo=2026-12-31T23:59:59.999Z"
          }
        },
        {
          "name": "Get by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/events/{{eventId}}"
          }
        },
        {
          "name": "Create (admin, multipart)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Summer Conference", "type": "text" },
                { "key": "description", "value": "Annual meetup", "type": "text" },
                { "key": "dateTime", "value": "2026-06-15T14:00:00.000Z", "type": "text" },
                { "key": "location", "value": "Main Hall", "type": "text" },
                { "key": "totalSeats", "value": "100", "type": "text" },
                { "key": "image", "type": "file", "src": "" }
              ]
            },
            "url": "{{baseUrl}}/api/events"
          }
        },
        {
          "name": "Update (admin)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Summer Conference 2026", "type": "text" },
                { "key": "description", "value": "Updated description", "type": "text" },
                { "key": "dateTime", "value": "2026-06-15T15:00:00.000Z", "type": "text" },
                { "key": "location", "value": "Main Hall", "type": "text" },
                { "key": "totalSeats", "value": "120", "type": "text" }
              ]
            },
            "url": "{{baseUrl}}/api/events/{{eventId}}"
          }
        },
        {
          "name": "Delete (admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/events/{{eventId}}"
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create booking",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"{{eventId}}\",\n  \"seats\": 2\n}"
            },
            "url": "{{baseUrl}}/api/bookings"
          }
        },
        {
          "name": "My bookings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/bookings/mine"
          }
        },
        {
          "name": "Cancel booking",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/bookings/{{bookingId}}"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Admin dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/dashboard/admin"
          }
        },
        {
          "name": "User dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/dashboard/user"
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "List reviews",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/events/{{eventId}}/reviews"
          }
        },
        {
          "name": "Create review",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Great event!\"\n}"
            },
            "url": "{{baseUrl}}/api/events/{{eventId}}/reviews"
          }
        }
      ]
    }
  ]
}
